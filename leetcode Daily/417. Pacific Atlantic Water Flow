   void bfs(queue<pair<int,int>>& q, vector<vector<int>>& visited, vector<vector<int>>& heights) {
    int m = heights.size(), n = heights[0].size();
    vector<int> dir = {0,1,0,-1,0};
    while(!q.empty()){
        auto [r,c]=q.front();q.pop();
        for(int i=0;i<4;i++){
            int nr=r+dir[i],nc=c+dir[i+1];
            if(nr>=0&&nr<m&&nc>=0&&nc<n&&!visited[nr][nc]&&heights[nr][nc]>=heights[r][c]){
                visited[nr][nc]=1;
                q.push({nr,nc});
            }
        }
    }
}

vector<vector<int>> pacificAtlantic(vector<vector<int>>& heights) {
    int m=heights.size(),n=heights[0].size();
    vector<vector<int>> pac(m,vector<int>(n,0)),atl(m,vector<int>(n,0));
    queue<pair<int,int>> qp,qa;
    for(int i=0;i<m;i++){pac[i][0]=1;qp.push({i,0});atl[i][n-1]=1;qa.push({i,n-1});}
    for(int j=0;j<n;j++){pac[0][j]=1;qp.push({0,j});atl[m-1][j]=1;qa.push({m-1,j});}
    bfs(qp,pac,heights);
    bfs(qa,atl,heights);
    vector<vector<int>> res;
    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            if(pac[i][j]&&atl[i][j])res.push_back({i,j});
        }
    }
    return res;
}
